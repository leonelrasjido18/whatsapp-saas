# ============================================================
# Supabase (required — NEXT_PUBLIC_* are exposed to browser)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service_role bypasses RLS — server-only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# YCloud (WhatsApp provider)
# NOT env vars — configured PER WORKSPACE inside the app at
# Settings → Integraciones (API key + webhook signing secret, encrypted at rest).
# Each client/workspace has its own YCloud credentials and its own webhook URL.
# ============================================================

# ============================================================
# OpenRouter (LLM gateway) — server-only
# ============================================================
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# ============================================================
# HighLevel (CRM sync + calendar booking)
# No env vars needed — configured per workspace in Settings → Integraciones
# with a Private Integration Token (PIT) + Location ID + Calendar ID.
# ============================================================

# ============================================================
# Meta (Facebook Messenger + Instagram DM) — server-only
# ONE centralized Meta App owned by the SaaS; tenants connect their
# Facebook Page / Instagram account via OAuth in Settings → Integraciones.
# META_VERIFY_TOKEN is an invented string that must match the Webhooks
# configuration in the Meta App dashboard (callback: /api/webhooks/meta).
# NEXT_PUBLIC_APP_URL must be public HTTPS for OAuth + webhooks
# (use a cloudflared/ngrok tunnel in local dev).
# ============================================================
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-webhook-verify-token

# ============================================================
# Encryption key for tenant credentials at rest (SEC-03)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# server-only, rotate every 90 days (bump ENCRYPTION_KEY_VERSION)
# ============================================================
ENCRYPTION_KEY=your-32-bytes-base64-encoded-key
ENCRYPTION_KEY_VERSION=v1

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================================
# Buffer process internal endpoint (SEC-05) — server-only
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')" | tr -d '\n'
# ============================================================
BUFFER_PROCESS_SECRET=your-buffer-process-secret-hex

# ============================================================
# Vercel Cron secret (set automatically by Vercel, add for local testing)
# ============================================================
CRON_SECRET=your-cron-secret
